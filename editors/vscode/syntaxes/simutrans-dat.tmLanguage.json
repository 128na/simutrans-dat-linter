{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "simutrans-dat",
  "scopeName": "source.simutrans-dat",
  "patterns": [
    {
      "include": "#comment"
    },
    {
      "include": "#lines"
    }
  ],
  "repository": {
    "comment": {
      "patterns": [
        {
          "name": "comment.line.simutrans-dat",
          "match": "^#.*"
        },
        {
          "name": "comment.line.simutrans-dat",
          "match": "^-+$"
        }
      ]
    },
    "lines": {
      "patterns": [
        {
          "match": "^([^=]+)(=> |=)?((\\d+)|([A-Za-z,_]+)|(.+))?$",
          "captures": {
            "1": {
              "patterns": [
                {
                  "include": "#defined_keys"
                },
                {
                  "include": "#direction_and_number"
                }
              ]
            },
            "2": {
              "patterns": [
                {
                  "include": "#equal"
                }
              ]
            },
            "4": {
              "patterns": [
                {
                  "include": "#numeric"
                }
              ]
            },
            "5": {
              "patterns": [
                {
                  "include": "#defined_values"
                }
              ]
            },
            "6": {
              "patterns": [
                {
                  "include": "#general_value"
                }
              ]
            }
          }
        }
      ],
      "repository": {
        "numeric": {
          "patterns": [
            {
              "name": "constant.numeric.simutrans-dat",
              "match": "-?\\d+"
            }
          ]
        },
        "defined_keys": {
          "patterns": [
            {
              "name": "storage.type.defined-keys.simutrans-dat",
              "match": "^(?i:animation_time_closed|probability_to_spawn|production_per_field|animation_time_open|station_maintenance|distributionweight|electricity_amount|electricity_demand|expand_probability|extension_building|is_longblocksignal|preservation_month|allow_underground|electricity_boost|front_closedimage|is_prioritysignal|pillar_asymmetric|preservation_year|freightimagetype|passenger_demand|station_capacity|storage_capacity|front_openimage|passenger_boost|pillar_distance|steps_per_frame|weight_per_unit|animation_time|expand_minimum|noconstruction|outputcapacity|sound_interval|end_of_choose|frontdiagonal|frontimageup2|inputcapacity|inputsupplier|no_foreground|smokelifetime|station_price|backdiagonal|backimageup2|draw_as_ding|enables_post|enables_ware|expand_range|expand_times|freightimage|frontimageup|frontpillar2|is_presignal|loading_time|needs_ground|outputfactor|productivity|retire_month|spawn_weight|start_fields|trees_on_top|backimageup|backpillar2|closedimage|enables_pax|engine_type|frontimage2|frontpillar|frontstart2|inputfactor|intro_month|mail_demand|maintenance|offset_left|own_waytype|retire_year|runningcost|smokeoffset|smokeuplift|speed_bonus|system_type|backimage2|backpillar|backstart2|clip_below|constraint|emptyimage|fixed_cost|free_route|frontimage|frontramp2|frontstart|intro_year|is_private|mail_boost|max_fields|max_height|max_lenght|max_length|max_weight|min_fields|outputgood|single_way|sound_name|axle_load|backimage|backramp2|backstart|copyright|frontramp|inputgood|is_signal|min_speed|openimage|pax_level|smoketile|backramp|capacity|climates|diagonal|has_snow|location|mapcolor|sound_nr|topspeed|freight|imageup|payload|seasons|waytype|chance|cursor|fields|length|metric|noinfo|offset|weight|image|level|power|range|smoke|sound|speed|value|catg|cost|dims|gear|icon|name|type|obj)"
            }
          ]
        },
        "defined_values": {
          "patterns": [
            {
              "name": "storage.type.waytypes.simutrans-dat",
              "match": "\\b(?i:none|road|track|electrified_track|maglev_track|monorail_track|narrowgauge_track|water|air|schiene_tram|tram_track|power|decoration)$"
            },
            {
              "name": "storage.type.directions.simutrans-dat",
              "match": "\\b(?i:s|w|sw|se|n|e|ne|nw)$"
            },
            {
              "name": "storage.type.building-types.simutrans-dat",
              "match": "\\b(?i:monorailstop|extension|railstop|airport|busstop|carstop|harbour|station|habour|depot|wharf|dock|hall|post|shed|stop|any|com|cur|fac|ind|mon|res|tow|hq)$"
            },
            {
              "name": "storage.type.locations.simutrans-dat",
              "match": "\\b(?i:forest|river|shore|water|city|land)$"
            },
            {
              "name": "storage.type.climates.simutrans-dat",
              "match": "\\b(?i:mediterran|temperate|arctic|desert|tropic|tundra|rocky|water|sea)$"
            },
            {
              "name": "storage.type.skin-names.simutrans-dat",
              "match": "\\b(?i:NarrowgaugeStop|ToolsBackground|ClimateTexture|fastforwardsym|MessageOptions|TunnelTexture|ColorOptions|Construction|DialogeTools|GeneralTools|LightTexture|MonorailStop|station_type|Checkbutton|Electricity|PowerSource|Roundbutton|SimpleTools|timelinesym|CompassIso|CompassMap|MaglevStop|networksym|Passagiere|ShoreTrans|SlopeTrans|Editfield|Posbutton|PowerDest|Scrollbar|TrainStop|BarTools|Basement|NewWorld|pausesym|ShipStop|Sidewalk|TramStop|AirStop|BigLogo|Borders|Builder|BusStop|CarStop|Divider|Listbox|Message|NewYear|NoRoute|Outside|Seasons|Unhappy|Button|Gadget|InTown|Marked|Marker|Slopes|Fence|Flags|Happy|Mouse|Shore|Waren|Water|Back|Logo|Post)$"
            }
          ]
        },
        "general_value": {
          "patterns": [
            {
              "match": "[.,](-?\\d+)|((-?\\d+),)+?(-?\\d+)",
              "captures": {
                "1": {
                  "patterns": [
                    {
                      "include": "#numeric"
                    }
                  ]
                },
                "2": {
                  "patterns": [
                    {
                      "include": "#numeric"
                    }
                  ]
                },
                "3": {
                  "patterns": [
                    {
                      "include": "#numeric"
                    }
                  ]
                },
                "4": {
                  "patterns": [
                    {
                      "include": "#numeric"
                    }
                  ]
                }
              }
            }
          ]
        },
        "direction_and_number": {
          "patterns": [
            {
              "name": "variable.parameter.direction-and-number.simutrans-dat",
              "match": "\\[(?i:s|w|sw|se|n|e|ne|nw|-|\\d+)\\]"
            }
          ]
        },
        "equal": {
          "patterns": [
            {
              "name": "keyword.operator.equal.simutrans-dat",
              "match": "=> |="
            }
          ]
        }
      }
    }
  }
}
