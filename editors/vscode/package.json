{
  "name": "simutrans-dat-linter",
  "displayName": "Simutrans dat_linter",
  "description": "Surfaces dat_linter diagnostics for Simutrans .dat files in VSCode's Problems panel.",
  "version": "0.1.0",
  "publisher": "128na",
  "license": "MIT",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "This extension runs the dat_linter executable (its path is configurable per-workspace) against .dat files as soon as a workspace is opened, which is unsafe to do for untrusted/third-party workspaces."
    }
  },
  "categories": [
    "Linters"
  ],
  "keywords": [
    "simutrans",
    "makeobj",
    "linter",
    "dat"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/128na/simutrans-dat-linter.git",
    "directory": "editors/vscode"
  },
  "bugs": {
    "url": "https://github.com/128na/simutrans-dat-linter/issues"
  },
  "homepage": "https://github.com/128na/simutrans-dat-linter",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "configuration": {
      "title": "Simutrans dat_linter",
      "properties": {
        "simutransDatLinter.executablePath": {
          "type": "string",
          "default": "dat_linter",
          "description": "Path to the dat_linter executable. Defaults to relying on PATH."
        },
        "simutransDatLinter.configPath": {
          "type": "string",
          "default": "",
          "description": "Explicit path to a dat_linter.toml config file, passed via --config. Empty = let dat_linter auto-discover dat_linter.toml in the workspace folder root (falls back to all-rules-enabled defaults if not found; dat_linter no longer auto-generates it -- run `dat_linter init` there to create one)."
        }
      }
    },
    "languages": [
      {
        "id": "simutrans-dat",
        "aliases": [
          "Simutrans dat"
        ],
        "extensions": [
          ".dat"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "simutrans-dat",
        "scopeName": "source.simutrans-dat",
        "path": "./syntaxes/simutrans-dat.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "simutrans-dat",
        "path": "./snippets/snippets.json"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "npm run pretest && vscode-test",
    "generate:grammar": "node scripts/generate-grammar.mjs",
    "test:snippets": "node scripts/lint-snippets.mjs",
    "test:grammar": "vscode-tmgrammar-snap \"fixtures/*.dat\" -s source.simutrans-dat -g syntaxes/simutrans-dat.tmLanguage.json"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.9",
    "@types/node": "^20.16.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "typescript": "^5.7.2",
    "vscode-tmgrammar-test": "^0.1.3"
  }
}
